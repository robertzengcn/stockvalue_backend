{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 FastAPI: Debug with uv (Recommended)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "stockvaluefinder.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder",
      "python": "${workspaceFolder}/stockvaluefinder/.venv/bin/python"
    },
    {
      "name": "Python: FastAPI Application",
      "type": "debugpy",
      "request": "launch",
      "module": "stockvaluefinder.main",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    },
    {
      "name": "Python: Current File (.py only)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      }
    },
    {
      "name": "Python: pytest - All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    },
    {
      "name": "Python: pytest - Current File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    },
    {
      "name": "Python: pytest - Current Function",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-k",
        "${functionName}",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    },
    {
      "name": "Python: pytest with Coverage",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests",
        "--cov=.",
        "--cov-report=html",
        "--cov-report=term-missing",
        "-v"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    },
    {
      "name": "Python: Module Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "${input:moduleName}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/stockvaluefinder"
      },
      "cwd": "${workspaceFolder}/stockvaluefinder"
    }
  ],
  "inputs": [
    {
      "id": "moduleName",
      "type": "promptString",
      "description": "Enter Python module name (e.g., stockvaluefinder.modules.valuation)"
    }
  ]
}
