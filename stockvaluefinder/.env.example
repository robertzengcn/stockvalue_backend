# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/stockvaluefinder

# Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6380/0

# Data Sources (all free - no API keys needed!)
# AKShare: Primary source (open-source, community-maintained)
ENABLE_AKSHARE=true

# efinance: Secondary source (official East Money library)
ENABLE_EFINANCE=true

# Tushare: Optional source (requires API token from https://tushare.pro)
TUSHARE_TOKEN=

# Development Mode (use mock data when all sources fail)
# Set to "true" for local development, "false" for production
DEVELOPMENT_MODE=false

# LLM API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Application
LOG_LEVEL=INFO
CACHE_TTL=86400
