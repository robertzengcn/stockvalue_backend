# Production Environment Variables for StockValueFinder
# Copy this file to production.env and fill in the actual values

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string (required)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://stockvaluefinder:CHANGE_ME@localhost:5433/stockvaluefinder

# =============================================================================
# Vector Database (Qdrant)
# =============================================================================
# Qdrant URL for RAG operations (required)
QDRANT_URL=http://localhost:6333

# =============================================================================
# Cache (Redis)
# =============================================================================
# Redis connection string (required)
REDIS_URL=redis://localhost:6380/0

# =============================================================================
# External APIs
# =============================================================================
# Tushare Pro API token (required for A-share data)
# Get your token at: https://tushare.pro/
TUSHARE_TOKEN=YOUR_TUSHARE_TOKEN_HERE

# Anthropic API key for Claude LLM (required for AI analysis)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Optional: OpenAI API key as fallback
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# =============================================================================
# Application Configuration
# =============================================================================
# Application environment (development, staging, production)
ENV=production

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Security
# =============================================================================
# Secret key for session encryption (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://your-frontend.example.com

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable calculation sandbox (true/false)
ENABLE_CALCULATION_SANDBOX=false

# Enable/disable RAG processing (true/false)
ENABLE_RAG_PROCESSING=false

# Enable/disable agent orchestration (true/false)
ENABLE_AGENT_ORCHESTRATION=false

# =============================================================================
# Performance Tuning
# =============================================================================
# Worker count for uvicorn
WORKERS=4

# Maximum request size (MB)
MAX_REQUEST_SIZE=10

# Database pool size
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Enable Prometheus metrics (true/false)
ENABLE_METRICS=true

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=YOUR_SENTRY_DSN_HERE

# =============================================================================
# Rate Limiting
# =============================================================================
# Rate limit for API endpoints (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# Data Retention
# =============================================================================
# Cache TTL in seconds
CACHE_TTL=3600

# Session timeout in seconds
SESSION_TIMEOUT=86400
